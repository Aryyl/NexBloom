<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/widget_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NexBloom"
            android:textColor="@color/widget_text_main"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_header_plus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⊕"
            android:textSize="18sp"
            android:textColor="@color/widget_text_muted" />
    </LinearLayout>

    <!-- MIDDLE: Attendance + Tasks -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp">

        <!-- Attendance Card -->
        <LinearLayout
            android:id="@+id/widget_attendance_card"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_card_background"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp">

            <TextView
                android:id="@+id/widget_attendance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTENDANCE"
                android:textColor="@color/widget_text_sub"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal">

                <ProgressBar
                    android:id="@+id/widget_attendance_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/widget_circular_progress" />

                <ProgressBar
                    android:id="@+id/widget_attendance_progress_dark"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:visibility="gone"
                    android:progressDrawable="@drawable/widget_circular_progress_dark" />

                <TextView
                    android:id="@+id/widget_attendance_pct"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="--"
                    android:textColor="@color/widget_text_main"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/widget_attendance_goal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal: 75%"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Tasks Card -->
        <LinearLayout
            android:id="@+id/widget_tasks_card"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_card_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/widget_tasks_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TASKS"
                    android:textColor="@color/widget_text_sub"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_tasks_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Pending"
                    android:textColor="@color/widget_primary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Task 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/widget_task1_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ "
                    android:textColor="@color/widget_primary"
                    android:textSize="14sp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_task1_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No tasks"
                        android:textColor="@color/widget_text_main"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/widget_task1_priority"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due today"
                        android:textColor="@color/widget_priority_high"
                        android:textSize="8sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Task 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/widget_task2_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ "
                    android:textColor="@color/widget_primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/widget_task2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/widget_text_sub"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Task 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/widget_task3_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ "
                    android:textColor="@color/widget_primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/widget_task3_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/widget_text_sub"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- SCHEDULE SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/widget_schedule_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_card_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/widget_schedule_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY'S SCHEDULE"
                android:textColor="@color/widget_text_sub"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Schedule Row 1 -->
            <LinearLayout
                android:id="@+id/widget_schedule_row1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/widget_schedule_bar1"
                    android:layout_width="4dp"
                    android:layout_height="30dp"
                    android:background="@color/widget_primary"
                    android:layout_marginEnd="10dp"
                    android:text="" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_class1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No classes today"
                        android:textColor="@color/widget_text_main"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/widget_class1_room"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/widget_text_muted"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/widget_class1_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/widget_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/widget_class1_eta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/widget_text_muted"
                        android:textSize="8sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Schedule Row 2 -->
            <LinearLayout
                android:id="@+id/widget_schedule_row2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_schedule_bar2"
                    android:layout_width="4dp"
                    android:layout_height="30dp"
                    android:background="@color/widget_schedule_bar_inactive"
                    android:layout_marginEnd="10dp"
                    android:text="" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_class2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/widget_text_main"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/widget_class2_room"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/widget_text_muted"
                        android:textSize="9sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_class2_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/widget_text_sub"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom accent bar -->
    <TextView
        android:id="@+id/widget_accent_bar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/widget_accent_bar_bg"
        android:text="" />

</LinearLayout>
