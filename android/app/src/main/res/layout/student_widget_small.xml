<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#3730A3"
    android:padding="14dp"
    android:gravity="center">

    <!-- Attendance % (large) -->
    <TextView
        android:id="@+id/widget_attendance_pct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="–%"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Attendance label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Attendance"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:alpha="0.75"
        android:layout_marginBottom="10dp" />

    <!-- Divider -->
    <TextView
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:background="#55FFFFFF"
        android:layout_marginBottom="10dp"
        android:text="" />

    <!-- Pending tasks -->
    <TextView
        android:id="@+id/widget_pending_tasks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="– Tasks"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Dummy views to prevent Kotlin RemoteViews errors if IDs are referenced -->
    <TextView android:id="@+id/widget_next_event_title" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/widget_next_event_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/widget_status_line" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/widget_attendance_dot" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</LinearLayout>
